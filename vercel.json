{
  "experimentalServices": [
    {
      "name": "web",
      "root": ".",
      "framework": "vite",
      "buildCommand": "npm run build",
      "outputDirectory": "public/build"
    }
  ],
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}